# SKC Live Translation — Environment Variables
#
# HOW TO SET UP:
#   1. Copy this file to .env  (cp .env.example .env)
#   2. Replace the placeholder below with your real Gemini API key
#   3. Never commit .env to git — it is already in .gitignore
#
# WHERE TO GET THE KEY:
#   Google AI Studio → https://aistudio.google.com/apikey
#   The key must have the Gemini Live API enabled.

GEMINI_API_KEY=your_api_key_here
